@import colors

.fav-group-picker-overlay
    position: fixed
    top: 0
    left: 0
    right: 0
    bottom: 0
    background: rgba(0, 0, 0, 0.5)
    z-index: 1000
    display: flex
    align-items: center
    justify-content: center

.fav-group-picker
    background: $window-color
    color: $text-color
    width: 90%
    max-width: 26em
    max-height: 80vh
    overflow-y: auto
    padding: 1.5em
    box-shadow: 0 0.2em 1em rgba(0, 0, 0, 0.4)

    h2
        margin: 0 0 0.8em 0
        font-size: 1.2em

    ul.groups
        list-style-type: none
        margin: 0 0 1em 0
        padding: 0
        li
            margin: 0.3em 0
            label
                display: flex
                align-items: center
                gap: 0.5em
                cursor: pointer
            .name
                flex-grow: 1
            .default-badge
                font-size: 0.75em
                color: $main-color
                border: 1px solid $main-color
                border-radius: 0.3em
                padding: 0 0.3em
            .count
                color: $inactive-link-color
                font-size: 0.85em

    .create-row
        display: flex
        gap: 0.5em
        margin-bottom: 0.8em
        input
            flex-grow: 1

    .messages
        color: #c33
        min-height: 1em
        font-size: 0.9em

    .buttons
        text-align: right

.darktheme .fav-group-picker
    background: $window-color-darktheme
    color: $text-color-darktheme
