<p><%= ctx.t('help.keyboard.intro') %></p>

<table>
    <thead>
        <tr>
            <th><%= ctx.t('help.keyboard.hotkey') %></th>
            <th><%= ctx.t('help.keyboard.description') %></th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><kbd>Q</kbd></td>
            <td><%= ctx.t('help.keyboard.focusSearch') %></td>
        </tr>

        <tr>
            <td><kbd>A</kbd> and <kbd>D</kbd>, <kbd>←</kbd> and <kbd>→</kbd></td>
            <td><%= ctx.t('help.keyboard.navigate') %></td>
        </tr>

        <tr>
            <td><kbd>F</kbd></td>
            <td><%= ctx.t('help.keyboard.cycleFit') %></td>
        </tr>

        <tr>
            <td><kbd>E</kbd></td>
            <td><%= ctx.t('help.keyboard.editPost') %></td>
        </tr>

        <tr>
            <td><kbd>P</kbd></td>
            <td><%= ctx.t('help.keyboard.focusPost') %></td>
        </tr>

        <tr>
            <td><kbd>Delete</kbd></td>
            <td><%= ctx.t('help.keyboard.deletePost') %></td>
        </tr>
    </tbody>
</table>

<p><%= ctx.t('help.keyboard.accessKeys') %></p>
